# EzPoint API
EZPOINT_EMPRESA=
EZPOINT_USUARIO=
EZPOINT_SENHA=

# Tolerâncias (minutos)
TOL_MIN=10
INTERVAL_TOL_MIN=10

# Dashboard
AUTO_REFRESH_SEC=30

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USUARIO=
SMTP_SENHA=
EMAIL_REMETENTE_NOME=Dashboard Ponto
EMAIL_ASSUNTO=Relatório Diário de Apontamentos

# Autenticação
ADMIN_EMAIL=           # e-mail do usuário admin inicial
AUTH_COOKIE_SECRET=    # gerar com: python -c "import secrets; print(secrets.token_hex(32))"

# Banco (Railway Volume — deixar vazio para uso local)
DB_PATH=/mnt/data/ezpoint.db
